  "manualFallback": {
    "enabled": true,
    "permission": "activeTab",
    "buttonLabel": "Run Role Reveal on this job",
    "description": "Allows the user to run Role Reveal manually on company career sites with custom domains."
  },
  "pageValidation": {
    "requireTopFrame": true,
    "requireCanonicalJobKey": true,
    "minimumTitleLength": 3,
    "minimumCompanyLength": 2,
    "minimumDescriptionLength": 200,
    "acceptedSignals": [
      "job-posting-json-ld",
      "known-job-url",
      "known-ats-selector"
    ],
    "rejectPageTypes": [
      "search-results-without-selected-job",
      "generic-career-homepage",
      "login-page",
      "application-form",
      "employer-homepage",
      "ats-dashboard"
    ]
  }
